{
  "name": "miniprogram-browser",
  "version": "0.1.0-beta.5",
  "description": "面向微信小程序的 agent-browser 风格自动化 CLI；配套 skill 通过 skills/miniprogram-browser 分发。",
  "keywords": [
    "wechat",
    "miniprogram",
    "automation",
    "cli",
    "agent",
    "opencode"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DoraemonHugU/miniprogram-browser.git"
  },
  "homepage": "https://github.com/DoraemonHugU/miniprogram-browser#readme",
  "bugs": {
    "url": "https://github.com/DoraemonHugU/miniprogram-browser/issues"
  },
  "bin": {
    "miniprogram-browser": "scripts/miniprogram-browser.cjs"
  },
  "files": [
    "README.md",
    "LICENSE",
    "scripts/miniprogram-browser.cjs",
    "scripts/lib/"
  ],
  "scripts": {
    "test:node": "node --test tests/*.test.cjs",
    "test:image-processing": "python scripts/run-image-processing-tests.py",
    "test": "npm run test:node && npm run test:image-processing",
    "pack:check": "npm pack --dry-run"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "fontkit": "^2.0.4",
    "jimp": "0.6.4",
    "miniprogram-automator": "0.12.1",
    "pureimage": "^0.4.18"
  }
}
